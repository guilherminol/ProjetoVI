# PostgreSQL
POSTGRES_USER=rag
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ragdb

# API
DATABASE_URL=postgresql+asyncpg://rag:changeme@db:5432/ragdb
OPENROUTER_API_KEY=sk-or-...
ADMIN_API_KEY=changeme-admin-key

# Embedding (locked — do not change)
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536

# JWT Auth (Phase 2) — generate: openssl rand -hex 32
JWT_SECRET_KEY=changeme-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM (Phase 2)
LLM_MODEL=anthropic/claude-3-5-haiku
